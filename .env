# ─── GoShareBD Mobile — Environment Variables ─────────────────────────────────
#
# Expo reads variables prefixed with EXPO_PUBLIC_ and makes them available
# in your JS bundle via process.env.EXPO_PUBLIC_*
#
# NEVER put secrets (DB credentials, private keys) here.
# These are embedded in the JS bundle and visible to anyone who decompiles it.

# Your deployed Next.js site URL — no trailing slash
EXPO_PUBLIC_API_URL="https://gosharebd.vercel.app"