{
  "expo": {
    "name": "GoShareBD",
    "slug": "gosharebd",
    "owner": "gosharebd",
    "version": "1.0.0",
    "description": "Explore the beauty of Bangladesh with GoShareBD.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gosharebd",
    "userInterfaceStyle": "automatic",
    

    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#208AEF"
    },

    "ios": {
      "icon": "./assets/expo.icon/icon.json",
      "bundleIdentifier": "com.gosharebd.app",
      "supportsTablet": true
    },

    "android": {
      "package": "com.gosharebd.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5EA500",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-system-ui",
        {
          "userInterfaceStyle": "automatic",
          "backgroundColor": {
            "dark": "#09090b",
            "light": "#ffffff"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "eas": {
      "projectId": "47ae078d-f72f-46db-af6d-1a6844572250",
      "userInterfaceStyle": "automatic"
      }
    }
  }
}